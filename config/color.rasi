@import "colors.rasi"

/*****----- The Wall — Iconmenu / Wifi / Listmenu (light) -----*****/
* {
    background:     @snow-t;
    background-alt: @ice-t;
    foreground:     @slate;
    foreground-alt: @steel;
    selected:       @slate;
    selected-alt:   @slate-t;
    grey-alt:       @frost;
    element:        @snow-dim;
    red:            @mist;
    green:          @steel;
    yellow:         @slate;
}
