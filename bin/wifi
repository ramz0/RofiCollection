#!/usr/bin/env bash
#
## Author   : mdfk@Elite <2022>
## Github   : @mdfk15
#
####### Rofi Wifi #######

# Icons
icon_header=$(printf '')     # fa-globe (header)
icon_wifi=$(printf '\uf1eb')       # fa-wifi (connect)
icon_wifi_off=$(printf '\uf204')   # fa-toggle-off (disconnect)
icon_scan=$(printf '\uf002')       # fa-search (scan)

# Functions
options() {
	title='Wireless'
	icon="$icon_header"
	status=$(nmcli g)
	current=$(nmcli -t -f NAME c show --active | grep -v lo)
	interface=$(ip -br a | grep -v lo | awk '{print $1}')
	ipv4=$(ip -4 -br a | grep -v lo | awk '{print $3}')
	ipv6=$(ip -6 -br a | grep -v lo | awk '{print $3}')

	status_options "$icon_wifi" "$icon_wifi_off"
	list="$icon_scan"
	options="$connection\n$list\n$power"
	[ -n "$current" ] && title="$current" || title="$interface"
	[ -n "$ipv4" ] && message+="$ipv4"
	[ -n "$ipv6" ] && message+="\n$ipv6"
	message=$(echo -e "$message")
}

scanning_opt() {
	notify-send -a "Wireless" "Scanning networks" -t 10000
	nmcli -f SSID dev wifi | tail -n +2 | sed '/^--/d' > $path/wifi_list
	element_list="$(cat $path/wifi_list)"
	title=$(nmcli -t -f NAME c show --active | grep -v lo)
}

handle_option() {
	if [ $1 == 'connection' ]; then
		message=''
		if [[ $status =~ disconnected ]]; then
			nmcli dev connect wlo1 >/dev/null
			sleep 1
		else
			nmcli dev disconnect wlo1 >/dev/null
		fi
	elif [ $1 == 'list' ]; then
		scanning_opt
		rm $path/wifi_list
		menu_list
	elif [ $1 == 'power' ]; then
		if [[ $status =~ disabled ]]; then
			nmcli radio wifi on >/dev/null
			sleep 3
		else
			nmcli radio wifi off >/dev/null
		fi
	else
		exit
	fi
	main_menu
}

element_option() {
	net_ssid=$(echo "$chosen" | xargs)
	[ -n "$net_ssid" ] || exit
	if [[ "$know" =~ "$net_ssid" ]]; then
		notify-send -a "Wireless" "Connecting to $net_ssid" -t 5000
		nmcli device wifi connect "$net_ssid" && notify-send -a "Wireless" "Connected to $net_ssid" -t 4000
	else
		passphrase=$(confirm_pass)
		if [[ -n "$passphrase" ]]; then
			notify-send -a "Wireless" "Connecting to $net_ssid" -t 10000
			connection_err=$((nmcli device wifi connect "$net_ssid" password "$passphrase") 2>&1) && notify-send -a "Wireless" "Connected to $net_ssid" -t 4000
		else
			message="<span color='#f7768e'>Error, empty input</span>"
			menu_list
		fi
	fi
	sleep 0.5
	if ! [[ "$(nmcli -t -f NAME c show --active)" =~ "$net_ssid" ]]; then
		message="<span color='#f7768e'>Error ${connection_err##*:}</span>"
		menu_list
	else
		notify-send -a "Wireless" "Connected to $net_ssid" -t 4000
		exit 0
	fi
}

confirm_pass() {
	rofi -dmenu \
		-i \
		-password \
		-p "Wireless" \
		-mesg "Connecting to: $chosen" \
		-theme "$HOME/.config/rofi/config/confirm.rasi"
}

check_case() {
	case "$chosen" in
		$connection) handle_option 'connection' ;;
		$list)       handle_option 'list' ;;
		$power)      handle_option 'power' ;;
		$cancel)     exit ;;
		*)           exit ;;
	esac
}

# Resources
icon_type='wifi'
icon_current="know-alt"

# Lists
know=$(nmcli -f NAME connection show)

path=$(dirname "$0")
source $path/base.sh

case $1 in
	--status) pass ;;
	*)        main_menu ;;
esac
