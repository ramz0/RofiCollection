#!/usr/bin/env bash
#
## Author   : mdfk@Elite <2022>
## Github   : @mdfk15
#
####### Rofi Volume #######

path=$(dirname "$0")
source $path/base.sh

get_volume_state() {
    percentage=$(pamixer --get-volume)
    muted=$(pamixer --get-mute)
    mic_muted=$(pamixer --get-mute --source 1 2>/dev/null || echo "false")
}

options() {
    get_volume_state

    active=''
    urgent=''

    if [[ "$muted" == "true" ]]; then
        icon='\uf6a9'
        [ -n "$urgent" ] && urgent+=",0" || urgent="-u 0"
    else
        if [[ $percentage -le 30 ]]; then
            icon='\uf027'
        elif [[ $percentage -lt 70 ]]; then
            icon='\uf028'
        else
            icon='\uf029'
        fi
    fi

    if [[ "$mic_muted" == "true" ]]; then
        mic='\uf131'
    else
        mic='\uf130'
        [ -n "$active" ] && active+=",1" || active="-a 1"
    fi

    if [[ "$muted" == "true" ]]; then
        [ -n "$active" ] && active+=",0" || active="-a 0"
    fi

    options="$icon\n$mic"
    title="${percentage}%"
}

handle_option() {
    case "$1" in
        "$icon")
            pamixer --toggle-mute
            ;;
        "$mic")
            pamixer --source 1 --toggle-mute 2>/dev/null || notify-send "Mic toggle failed"
            ;;
    esac
}

check_case() {
    case "$chosen" in
        "$icon")
            handle_option "$icon";;
        "$mic")
            handle_option "$mic";;
    esac
    main_menu
}

title='Volume'
icon='\uf028'

main_menu